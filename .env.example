# ============================================================
# PolicyPulse — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# LLM Provider — set the one you want to use
# ------------------------------------------------------------
# Options: "openai" | "anthropic" | "google"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# Model names (defaults — override as needed)
OPENAI_MODEL=gpt-4o
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_CLASSIFIER_MODEL=gemini-2.0-flash

# ------------------------------------------------------------
# Data APIs (all free — register to get keys)
# ------------------------------------------------------------

# FRED — Federal Reserve Economic Data
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# BLS — Bureau of Labor Statistics
# Register at: https://www.bls.gov/developers/
BLS_API_KEY=

# BEA — Bureau of Economic Analysis
# Register at: https://apps.bea.gov/API/signup/
BEA_API_KEY=

# Tavily — Web search + CBO report search
# Register at: https://tavily.com
TAVILY_API_KEY=

# Semantic Scholar — Academic papers (optional, improves rate limits)
# Register at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Census Bureau API (optional)
# Register at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# OpenAlex polite pool email (optional)
OPENALEX_EMAIL=policypulse@hoohacks.io

# ------------------------------------------------------------
# Backend
# ------------------------------------------------------------
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# ------------------------------------------------------------
# Frontend
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Lightning / L402 (Praneeth)
# L402 payments handled by lnget (lightning-agent-tools).
# lnget config is auto-generated by the bootstrap script.
# ------------------------------------------------------------
APERTURE_URL=http://localhost:8081
LNGET_MAX_COST_SATS=500

# LLM Provider
GEMINI_API_KEY=your_gemini_key_here
LLM_PROVIDER=gemini
LLM_MODEL_NAME=gemini-2.0-flash
